---
// Arrays — composed from verbatim per-chapter fragments sliced out of the
// original monolithic index.html. The <article> wrapper is the book boundary;
// each fragment is one chapter, ready to be split into its own route later.
import intro from "./intro.html?raw";
import ch01 from "./ch01.html?raw";
import ch02 from "./ch02.html?raw";
import ch03 from "./ch03.html?raw";
import ch04 from "./ch04.html?raw";
import ch05 from "./ch05.html?raw";
import ch06 from "./ch06.html?raw";
import ch07 from "./ch07.html?raw";
import ch08 from "./ch08.html?raw";
import ch09 from "./ch09.html?raw";
import ch10 from "./ch10.html?raw";
import ch11 from "./ch11.html?raw";
import ch12 from "./ch12.html?raw";
import ch13 from "./ch13.html?raw";
import ch14 from "./ch14.html?raw";
import ch15 from "./ch15.html?raw";
import ch16 from "./ch16.html?raw";
import ch17 from "./ch17.html?raw";
---
<article id="arrays-deepdive" class="chapter">
<Fragment set:html={intro} />
<Fragment set:html={ch01} />
<Fragment set:html={ch02} />
<Fragment set:html={ch03} />
<Fragment set:html={ch04} />
<Fragment set:html={ch05} />
<Fragment set:html={ch06} />
<Fragment set:html={ch07} />
<Fragment set:html={ch08} />
<Fragment set:html={ch09} />
<Fragment set:html={ch10} />
<Fragment set:html={ch11} />
<Fragment set:html={ch12} />
<Fragment set:html={ch13} />
<Fragment set:html={ch14} />
<Fragment set:html={ch15} />
<Fragment set:html={ch16} />
<Fragment set:html={ch17} />
</article>
